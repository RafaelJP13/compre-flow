generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Company {
  id String @id @default(uuid())

  adminName     String
  adminEmail    String
  passwordAdmin String
  representante String
  fantasyName   String
  legalName     String
  cnpj          String @unique
  cnpj_status   String // "VALID", "INVALID"
  phone         String
  cep           String
  state         String
  city          String
  address       String

  branches Branch[]
  users    User[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([cnpj])
}

model User {
  id String @id @default(uuid())

  name     String
  email    String @unique
  password String

  role Role @default(EMPLOYEE)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([role])
}

model AuditLog {
  id String @id @default(cuid())

  userId    String?
  userEmail String?
  companyId String?
  action    String // e.g. "USER_CREATED", "ORDER_UPDATED"
  entity    String // e.g. "User", "Order", "Product"
  entityId  String?
  metadata  Json? // flexible payload (before/after, extra info)
  ip        String?
  userAgent String?
  requestId String?
  status    String // "SUCCESS" | "FAILURE"
  error     String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([companyId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

model Branch {
  id              String          @id @default(uuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  code            String?
  cnpj            String?         @unique
  phone           String?
  email           String?
  manager         String?
  cep             String?
  state           String?
  city            String?
  neighborhood    String?
  street          String?
  number          String?
  complement      String?
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  productBranches ProductBranch[]

  @@index([companyId])
}

model ProductBranch {
  id String @id @default(uuid())

  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quantity     Int      @default(0)
  minimumStock Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([productId, branchId])
  @@index([productId])
  @@index([branchId])
}

model Product {
  id String @id @default(uuid())

  companyId   String
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sku         String
  name        String
  description String?
  brand       String?
  ean         String?
  price       Decimal         @db.Decimal(10, 2)
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  branches    ProductBranch[]

  @@unique([companyId, sku])
  @@index([companyId])
}

enum Role {
  OWNER
  COMPANY_ADMIN
  EMPLOYEE
}
